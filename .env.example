# =============================================================================
# RFQ2BOQ Configuration
# All settings can be overridden via environment variables with RFQ2BOQ_ prefix
# =============================================================================

# -----------------------------------------------------------------------------
# Paths
# -----------------------------------------------------------------------------
# Directory containing the NER model files
RFQ2BOQ_MODEL_DIR=./models/ner-bert-bilstm-crf-v1

# Directory containing ontology JSON files (materials.json, standards.json, units.json, locations.json)
RFQ2BOQ_ONTOLOGY_DIR=./src/ontology

# Root data directory for jobs, results, etc.
RFQ2BOQ_DATA_DIR=./data

# Directory for synthetic training data
RFQ2BOQ_SYNTHETIC_DIR=./data/synthetic

# Directory for annotation files
RFQ2BOQ_ANNOTATIONS_DIR=./data/annotations

# Directory for report templates
RFQ2BOQ_TEMPLATES_DIR=./templates

# Directory for JSON schemas
RFQ2BOQ_SCHEMA_DIR=./schema

# -----------------------------------------------------------------------------
# OCR Settings
# -----------------------------------------------------------------------------
# Path to tesseract executable
RFQ2BOQ_TESSERACT_CMD=tesseract

# -----------------------------------------------------------------------------
# Quality Thresholds (0.0 - 1.0)
# -----------------------------------------------------------------------------
# Minimum OCR confidence threshold
RFQ2BOQ_OCR_CONFIDENCE_THRESHOLD=0.80

# Minimum entity confidence threshold for extraction
RFQ2BOQ_ENTITY_CONFIDENCE_THRESHOLD=0.70

# Minimum relation confidence threshold
RFQ2BOQ_RELATION_CONFIDENCE_THRESHOLD=0.60

# -----------------------------------------------------------------------------
# Processing Limits
# -----------------------------------------------------------------------------
# Maximum uploaded file size in MB
RFQ2BOQ_MAX_FILE_SIZE_MB=50

# Maximum number of pages to process per document
RFQ2BOQ_MAX_PAGES=200

# File size threshold (MB) for background processing
RFQ2BOQ_JOB_LARGE_FILE_SIZE_MB=5

# Page count threshold for background processing
RFQ2BOQ_JOB_LARGE_PAGE_COUNT=10

# Hours after which completed jobs are auto-deleted
RFQ2BOQ_JOB_CLEANUP_HOURS=24

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
# Host to bind the API server to
RFQ2BOQ_API_HOST=0.0.0.0

# Port to bind the API server to
RFQ2BOQ_API_PORT=8000

# API key for authentication (empty = no auth)
RFQ2BOQ_API_KEY=

# -----------------------------------------------------------------------------
# CORS Settings
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins
# Use "*" for all origins (not recommended for production)
# Example: "http://localhost:3000,https://example.com"
RFQ2BOQ_CORS_ORIGINS=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR
RFQ2BOQ_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Rate limit for /v1/extract endpoint (format: "number/unit")
# Supported units: second, minute, hour, day
RFQ2BOQ_RATE_LIMIT=10/minute

# -----------------------------------------------------------------------------
# OpenRouter Settings (Free Models)
# -----------------------------------------------------------------------------
# OpenRouter API key (get from https://openrouter.ai/keys)
# Free tier: no credit card required, ~20 req/min, 50 req/day
RFQ2BOQ_OPENROUTER_API_KEY=

# Default free model to use (openrouter/free auto-selects from available free models)
# Other popular free models (as of 2026):
# - google/gemma-4-31b-it:free
# - nvidia/nemotron-3-super-120b-a12b:free
# - openai/gpt-oss-120b:free
# - qwen/qwen3-coder:free
# - meta-llama/llama-3.3-70b-instruct:free
# - mistralai/mistral-small-3.1-24b-instruct:free
RFQ2BOQ_OPENROUTER_MODEL=openrouter/free

# OpenRouter API base URL
RFQ2BOQ_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -----------------------------------------------------------------------------
# NER Training Defaults
# -----------------------------------------------------------------------------
RFQ2BOQ_NER_LEARNING_RATE=2e-5
RFQ2BOQ_NER_BILSTM_LR=1e-3
RFQ2BOQ_NER_BATCH_SIZE=16
RFQ2BOQ_NER_EPOCHS=8
RFQ2BOQ_NER_WARMUP_RATIO=0.10

# -----------------------------------------------------------------------------
# Relation Extraction
# -----------------------------------------------------------------------------
# Maximum character distance for relation extraction
RFQ2BOQ_RE_MAX_DISTANCE_CHARS=500

# Maximum sentence gap for relation extraction
RFQ2BOQ_RE_MAX_SENTENCE_GAP=3

# -----------------------------------------------------------------------------
# Export
# -----------------------------------------------------------------------------
# Path to Excel template file
RFQ2BOQ_EXCEL_TEMPLATE=./templates/boq_template.xlsx
